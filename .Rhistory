#                                   e.g. to compare our calls against 10X
#   annotate_multiplets_seurat() -> add Human/Mouse/Multiplet + percents to Seurat
#   remove_multiplets_seurat()   -> (optional) drop multiplets for downstream work
#
# Key result on 12C: our method calls fewer multiplets than 10X (280 vs 480) but
# with higher distribution overlap (87.2% vs 81.7%) and lower mode difference
# (0.222 vs 0.331), and our set stays unimodal while 10X's is mouse-bimodal --
#   calculate_adaptive_metrics() -> score distribution quality (overlap, mode
#                                   difference, bimodality) for any multiplet set,
#                                   e.g. to compare our calls against 10X
#   annotate_multiplets_seurat() -> add Human/Mouse/Multiplet + percents to Seurat
#   remove_multiplets_seurat()   -> (optional) drop multiplets for downstream work
#
# Key result on 12C: our method calls fewer multiplets than 10X (280 vs 480) but
# with higher distribution overlap (87.2% vs 81.7%) and lower mode difference
# (0.222 vs 0.331), and our set stays unimodal while 10X's is mouse-bimodal --
# our calls are cleaner, and the extra cells 10X flags are the lower-quality ones
# Default run (baseline) — should give 280
res_default <- detect_multiplets(
fileIn = "C:/Users/gervenia/OneDrive - Virginia Commonwealth University/Desktop/Dr. Dozmorov/multipletR/for_Alex/12C_gem_classification.csv",
fileOut = tempfile(fileext = ".csv"),
plotPercent = FALSE, plotTotalReads = FALSE
)
# Adjusted run — change the starting thresholds and stopping criteria
res_adjusted <- detect_multiplets(
fileIn = "C:/Users/gervenia/OneDrive - Virginia Commonwealth University/Desktop/Dr. Dozmorov/multipletR/for_Alex/12C_gem_classification.csv",
fileOut = tempfile(fileext = ".csv"),
T1 = 60,          # narrower starting box (was 70)
T2 = 40,          # narrower (was 30)
T3 = 10,          # lower reads percentile (was 25)
overlapDrop = 5,  # stricter stopping (was 10)
modeDiff = 0.5,   # stricter (was 0.9)
plotPercent = FALSE, plotTotalReads = FALSE
)
cat("Default multiplets:", sum(res_default$our_classification == "Multiplet"), "\n")
cat("Adjusted multiplets:", sum(res_adjusted$our_classification == "Multiplet"), "\n")
?detect_multiplets
detect_multiplets(fileIn = "data.csv", fileOut = "out.csv", T1 = 65, overlapDrop = 5)
