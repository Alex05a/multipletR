prep_cells <- function(f) {
d  <- read.csv(f, check.names = FALSE)
mc <- intersect(c("mouse_reads","GRCm39","mm10","mm39"), names(d))[1]
cc <- data.frame(barcode=d$barcode, human_10x=d$GRCh38, mouse_10x=d[[mc]],
call_10x=d$call, stringsAsFactors=FALSE)
cc$total_reads   <- cc$human_10x + cc$mouse_10x
cc$pct_mouse_10x <- cc$mouse_10x / cc$total_reads * 100
cc
}
