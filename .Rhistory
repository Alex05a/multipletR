# 0. Setup: load the package and Seurat
# -----------------------------------------------------------------------------
# Load the multipletR package (adjust the path to wherever the package lives).
devtools::load_all("C:/Users/gervenia/OneDrive - Virginia Commonwealth University/Desktop/multipletR")
library(Seurat)
# Paths to the 12C data (adjust to your machine).
data_root  <- "C:/Users/gervenia/OneDrive - Virginia Commonwealth University/Desktop/Dr. Dozmorov/multipletR/for_Alex"
gem_file   <- file.path(data_root, "12C_gem_classification.csv")
matrix_dir <- file.path(data_root, "12C_filtered_feature_bc_matrix/filtered_feature_bc_matrix")
res <- detect_multiplets(
fileIn         = gem_file,
fileOut        = tempfile(fileext = ".csv"),  # use a real path to keep the output
plotPercent    = TRUE,
plotTotalReads = TRUE
)
# Look at the output: original data plus our three new columns.
head(res)
# How many multiplets did our method call?
table(res$our_classification)
# Rebuild the cell table (barcode, human/mouse reads, 10X call, percentages).
d  <- read.csv(gem_file)
cc <- data.frame(
barcode       = d$barcode,
human_10x     = d$GRCh38,
mouse_10x     = d$GRCm39,
call_10x      = ifelse(d$call == "GRCh38", "Human",
ifelse(d$call == "GRCm39", "Mouse", "Multiplet")),
total_reads   = d$GRCh38 + d$GRCm39,
pct_mouse_10x = d$GRCm39 / (d$GRCh38 + d$GRCm39) * 100,
pct_human_10x = d$GRCh38 / (d$GRCh38 + d$GRCm39) * 100
)
# The 10X multiplet set (barcodes 10X called "Multiplet").
tenx_set <- cc[cc$call_10x == "Multiplet", ]
# Our multiplet set (barcodes our method flagged).
our_bc  <- res$barcode[res$our_classification == "Multiplet"]
our_set <- cc[cc$barcode %in% our_bc, ]
# Score each set on distribution quality.
m_tenx <- calculate_adaptive_metrics(tenx_set)
m_our  <- calculate_adaptive_metrics(our_set)
# Assemble a side-by-side comparison table and print it.
comparison <- data.frame(
Method        = c("10X", "Ours"),
N             = c(m_tenx$n_cells,     m_our$n_cells),
Overlap_pct   = c(m_tenx$pct_overlap, m_our$pct_overlap),
Mode_diff     = c(m_tenx$diff_modes,  m_our$diff_modes),
Mouse_bimodal = c(m_tenx$mouse_bimodal, m_our$mouse_bimodal),
stringsAsFactors = FALSE
)
print(comparison)
counts   <- Read10X(data.dir = matrix_dir)
seurat12c <- CreateSeuratObject(
counts       = counts,
project      = "PDAC_12C",
min.cells    = 3,
min.features = 200
)
seurat12c
seurat12c <- annotate_multiplets_seurat(seurat12c, res)
# The new metadata columns now sit alongside Seurat's own per-cell metadata.
head(seurat12c@meta.data)
# Class counts: Human, Mouse, and the multiplets our method found.
table(seurat12c$multipletR_class)
seurat12c <- NormalizeData(seurat12c)
seurat12c <- FindVariableFeatures(seurat12c, nfeatures = 2000)
seurat12c <- ScaleData(seurat12c)
seurat12c <- RunPCA(seurat12c)
seurat12c <- RunUMAP(seurat12c, dims = 1:10)
DimPlot(seurat12c, reduction = "umap", group.by = "multipletR_class")
mult <- seurat12c@meta.data[seurat12c$multipletR_class == "Multiplet", ]
summary(mult$multipletR_pct_human)
summary(mult$multipletR_pct_mouse)
seurat12c_clean <- remove_multiplets_seurat(seurat12c, res)
seurat12c_clean   # fewer cells than before: the multiplets have been removed
