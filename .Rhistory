pbmc
head(pbmc@meta.data)
# Normalize the data (log-normalize the counts)
pbmc <- NormalizeData(pbmc)
# Find the most variable genes (the ones that distinguish cell types)
pbmc <- FindVariableFeatures(pbmc, nfeatures = 2000)
# Scale the data (center/standardize) for PCA
pbmc <- ScaleData(pbmc)
# PCA — reduce the ~2000 genes down to principal components
pbmc <- RunPCA(pbmc)
# Cluster the cells (find groups of similar cells)
pbmc <- FindNeighbors(pbmc, dims = 1:10)
pbmc <- FindClusters(pbmc, resolution = 0.5)
# UMAP — project cells into 2D for visualization
pbmc <- RunUMAP(pbmc, dims = 1:10)
